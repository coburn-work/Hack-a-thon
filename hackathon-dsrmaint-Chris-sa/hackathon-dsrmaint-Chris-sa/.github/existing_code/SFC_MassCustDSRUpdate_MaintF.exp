205:ON CLICK = 
BEGIN
	if last_sort = AS_ASC then
		sort_order = AS_DESC;	
		last_sort = AS_DESC;
	else
		sort_order = AS_ASC;
		last_sort = AS_ASC;
	endif; 
			
	ship_tbl.sort(ar_ship_key = sort_order);

END;

