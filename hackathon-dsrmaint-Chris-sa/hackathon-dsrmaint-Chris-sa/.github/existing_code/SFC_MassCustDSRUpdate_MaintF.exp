1086:ON SETVALUE =
DECLARE
i 		= integer not null default 1;
dsrrow 	= integer not null default 0;
ENDDECLARE
BEGIN
new_so_salsm_name = ut_emptystring;
SELECT :new_so_salsm_key = so_salsm_key, 
       :new_so_salsm_name = so_salsm_name 
FROM so_salsm_tbl
WHERE so_salsm_key = :new_so_salsm_key;
if ( iierrornumber !=0 ) then
		CallProc errortrap ( errornum = iierrornumber,
			frame_name = curframe.objectsource.name,
			tbl_name = 'so_salsm_tbl', 
			change_number = :change_number,
			id = '$_CurFld/1');
		resume;
        endif;

	if ( IIrowcount = 0 ) then
		curframe.beep(); 		
		MESSAGE 'DSR key does not exists!';
		new_so_salsm_key = ut_emptystring;
		RESUME;		
	endif;
	loadcustfrom = 'NewDSRField';
FOR i = 1 TO dsr_tbl.LASTROW do	
	IF :dsr_tbl[i].sel_tgl = 1 AND dsr_tbl[i].so_salsm_key != UT_EMPTYSTRING THEN
		dsrrow = i;
	ENDIF;
ENDFOR;

IF :new_so_salsm_key = :dsr_tbl[dsrrow].so_salsm_key THEN
	CURFRAME.BEEP();
	MESSAGE 'New DSR cannot be the same as the current DSR assigned to selected Customers!';
	CURFRAME.INPUTFOCUSFIELD = FIELD(new_so_salsm_key);
	RESUME;
ENDIF;
END;

