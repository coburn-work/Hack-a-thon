3943:on click =      /* update_btn */
declare
selected_rowcount	= integer not null default 0;
dsrrow 				= integer not null default 0;
i					= integer not null default 1;
today				= date not null;
enddeclare
begin

today = date(np_get_server_date(flag = 'T'));

IF new_so_salsm_key = ut_emptystring THEN
	CURFRAME.BEEP();
	MESSAGE 'DSR field cannot be blank!';
	CURFRAME.INPUTFOCUSFIELD = FIELD(new_so_salsm_key);
	RESUME;
ENDIF;

FOR i = 1 TO dsr_tbl.LASTROW do	
	IF :dsr_tbl[i].sel_tgl = 1 AND dsr_tbl[i].so_salsm_key != UT_EMPTYSTRING THEN
		dsrrow = i;
	ENDIF;
ENDFOR;

IF new_so_salsm_key = dsr_tbl[dsrrow].so_salsm_key THEN
	CURFRAME.BEEP();
	MESSAGE 'New DSR cannot be the same as the current DSR assigned to selected Customers!';
	CURFRAME.INPUTFOCUSFIELD = FIELD(new_so_salsm_key);
	RESUME;
ENDIF;

IF CurFrame.ConfirmPopup( messagetext = 'Are You Sure You Want To update the selected items?') = PU_OK THEN
	selrow = 1;
	FOR selrow = 1 TO  ship_tbl.LastRow do
			IF ship_tbl[selrow]._rowSelected = TRUE 
				and ship_tbl[selrow].ar_ship_key!= ut_emptystring then
				
				/*UPDATE TABLES HERE*/			
				
				UPDATE ar_ship_ext
				SET so_salsm_key = :new_so_salsm_key
				WHERE gl_cmp_key = :company_id
				AND so_brnch_key = :branch_id
				and ar_ship_key = :ship_tbl[selrow].ar_ship_key
				AND so_salsm_key = :dsr_tbl[dsrrow].so_salsm_key;
	
	
				if ( iierrornumber !=0 ) then
					CallProc errortrap ( errornum = iierrornumber,
						frame_name = curframe.objectsource.name,
						tbl_name = 'so_salsm_ext', 
						change_number = :change_number,
						id = '$_CurFld/1');
					rollback;
					resume;
				endif;
							
				IF :ship_tbl[selrow].sfc_oggrp_key != UT_EMPTYSTRING THEN				   
			   		UPDATE sfc_ordgde_tbl
					SET sfc_ordgde_chgdt = :today
					WHERE gl_cmp_key = :company_id
					AND so_brnch_key = :branch_id
					AND sfc_ordgde_key in (select sfc_ordgde_key
											from sfc_ogasgn_tbl
											where gl_cmp_key = :company_id
											and so_brnch_key = :branch_id
											and sfc_oggrp_key in (  select sfc_oggrp_key
																	from ar_ship_ext
																	where gl_cmp_key = :company_id
																	and so_brnch_key = :branch_id
																	and ar_ship_key = :ship_tbl[selrow].ar_ship_key)
											);	
					if ( iierrornumber !=0 ) then
						CallProc errortrap ( errornum = iierrornumber,
							frame_name = curframe.objectsource.name,
							tbl_name = 'so_salsm_ext', 
							change_number = :change_number,
							id = '$_CurFld/1');
						rollback;
						resume;
					endif;
				ENDIF;  
	
			
				
				commit;
				selected_rowcount = selected_rowcount + 1;
				
			ENDIF;
	ENDFOR;

	IF selected_rowcount <= 0 then
		CURFRAME.BEEP();
		MESSAGE 'Please select valid rows from the customer table.';
		RESUME;
	ENDIF;
		
	CALLPROC Load_DSR();
	CALLPROC Load_Customer(which_row = 1);	
	CallProc SetFrameMode ( cur_mode = FM_QUERY );
ENDIF;


end;       


	/*IF sfc_oggrp_key != UT_EMPTYSTRING THEN
		   IF v_so_salsm_key != so_salsm_key THEN		   
		   		UPDATE sfc_ordgde_tbl
				SET sfc_ordgde_chgdt = :today
				WHERE gl_cmp_key = :cmp_cde
				AND so_brnch_key = :so_brnch_key
				AND sfc_ordgde_key in (select sfc_ordgde_key
										from sfc_ogasgn_tbl
										where gl_cmp_key = :cmp_cde
										and so_brnch_key = :so_brnch_key
										and sfc_oggrp_key in (  select sfc_oggrp_key
																from ar_ship_ext
																where gl_cmp_key = :cmp_cde
																and so_brnch_key = :so_brnch_key
																and ar_ship_key = :ar_ship_key)
										);	
				IF iierrornumber != 0 THEN
				 	CurFrame.beep();
				 	callproc errortrap (errornum = iierrornumber,
										frame_name = CurFrame.objectsource.name,
										tbl_name = 'sfc_ordgde_tbl',
										change_number = :change_number,
										id = ' upd_btn - 2 ');
					CurFrame.purgeUserEvent();
					CurFrame.purgedbevent();
					return ProcReturn; 
	    		ENDIF;
		   ENDIF;  
		ENDIF;*/


