1663:on click =      /* update_btn */
declare
selected_rowcount	= integer not null default 0;
noderow = integer not null default 0;
i			= integer not null default 1;
enddeclare
begin

IF sfc_node_key = 0 THEN
	CURFRAME.BEEP();
	MESSAGE 'Node Key field cannot be zero!';
	CURFRAME.INPUTFOCUSFIELD = FIELD(sfc_node_key);
	RESUME;
ENDIF;
FOR i = 1 TO node_tbl.LASTROW do	
	IF :node_tbl[i].sel_tgl = 1 AND node_tbl[i].sfc_node_key != UT_EMPTYSTRING THEN
		noderow = i;
	ENDIF;
ENDFOR;
IF CurFrame.ConfirmPopup( messagetext = 'Are You Sure You Want To update the selected items?') = PU_OK THEN
	selrow = 1;
	FOR selrow = 1 TO  ship_tbl.LastRow do
			IF ship_tbl[selrow]._rowSelected = TRUE 
				and ship_tbl[selrow].ar_ship_key != ut_emptystring then
				
				/*UPDATE TABLES HERE*/
				UPDATE pc_spthdr_tbl
				SET sfc_node_key = :sfc_node_key
				WHERE gl_cmp_key = :company_id
				AND so_brnch_key = :branch_id
				AND pc_spthdr_key = :ship_tbl[selrow].pc_spthdr_key
				AND sfc_node_key = :node_tbl[noderow].sfc_node_key;
				
				
	
				if ( iierrornumber !=0 ) then
					CallProc errortrap ( errornum = iierrornumber,
						frame_name = curframe.objectsource.name,
						tbl_name = 'so_salsm_ext', 
						change_number = :change_number,
						id = '$_CurFld/1');
					rollback;
					resume;
				endif;						
				
				commit;
				selected_rowcount = selected_rowcount + 1;
				
			ENDIF;
	ENDFOR;
	
	IF selected_rowcount <= 0 then
		CURFRAME.BEEP();
		MESSAGE 'Please select valid rows from the customer table.';
		RESUME;
	ENDIF;
		
	CALLPROC Load_Node();
	CALLPROC Load_Customer(which_row = 1);	
	CallProc SetFrameMode ( cur_mode = FM_QUERY );
ENDIF;

end;       




