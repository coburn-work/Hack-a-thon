7077:/*  Frame: 
**  (Procedure:)
**  (Class:)
**  (Include Script:)
** 
**  Description: 
** 
**  Copyright: Shamrock Foods, Phoenix Arizona, 1998
**
** 
**
**  Change History:
**  
**  dd-mmm-yyyy <your name here> <change reference number and description>
**      <Comment regarding the change made>
	2/29/2007  Gayle Tan PTR# 8006 Status will be in production 2/27/2007
		This is a new frame to handle Customer Node Mass Update.
	3/12/2007	Gayle Tan 	Production Fix
		fixed sort issue behind dsr key and dsr name.
*/
INITIALIZE()=
DECLARE
   /*
   ** Template Added
   */
#  include UtHelpMenuVariables
   change_number   	= integer not null;
   proc_return   	= integer not null;
   ent_opt_array   	= ARRAY of FormField;
   SetFrameMode 	= procedure;
   set_color		= procedure;
   Load_Node		= procedure;
   Load_Customer	= procedure;
   rownum			= integer not null default 1;
   last_sort        = INTEGER NOT NULL DEFAULT as_asc;
   sort_order		= INTEGER NOT NULL DEFAULT as_asc;
   loadcustfrom		= varchar(25) not null default ' ';
   selrow 			= integer not null default 0;   
ENDDECLARE
BEGIN

   /*
   ** Change Number is displayed in about/help frame
   */
   change_number = 1;

   /*
   ** Template Added - Get all fields in the frame.
   */
   ent_opt_array = callproc get_fields_list(parent_frame = byref(CurFrame));

   /*  Hard Coded Username, incase program is run from developement. */
   IF usr_nam = UT_EMPTYSTRING THEN
      usr_nam = 'sct';
   ENDIF;

   proc_return = callproc s_common();
   IF proc_return = -1 THEN
      curframe.PurgeUserEvent();
      curframe.PurgeDBEvent();
      Return;
   ENDIF;

   /*
   ** Template Added - frame level security 
   */
   cmp_ID 	= :company_ID;
   cmp_name 	= :company_name;
   br_ID	= :branch_id;
   br_name	= :branch_name;
   CALLPROC secure_frame (client_frame = CurFrame);


   /*
   ** Template Added - Set Initial field Bias
   */
   frm_sts.clear();
   frm_sts[1].frm_name = CurFrame.ObjectSource.name;
   callproc user_frame_mode(current_frame = byref(curframe));
   if frm_sts[1].frm_mode = 'READ' THEN
	Field(menu.opt.add_menu).allbias = mb_disabled;
	Field(menu.opt.update_menu).allbias = mb_disabled;
	Field(menu.opt.delete_menu).allbias = mb_disabled;
   elseif frm_sts[1].frm_mode = 'NONE' THEN
	CurFrame.InfoPopup( messagetext = 'You do not have access to this frame.', messagetype = MT_ERROR);
	return;
   endif;
   CallProc SetFrameMode ( cur_mode = FM_QUERY );
   loadcustfrom = ' ';
   CALLPROC Load_Node();
end;

/*
** Template Added
**	The ChildSetValue event is triggered for a composite field when a user changes the value of a 
**	child field, in a field with a bias of FB_CHANGEABLE
** ApplyTemplate will change the contents of this event block
*/
ON ChildSetValue =
BEGIN
   CurFrame.StatusText = ' ';
   callproc NP_VerifyEmptyString(ent_opt_array = :ent_opt_array);
END;

/*
** Template Added
** 	The ChildSetValue event is triggered for a composite field when a user changes the value of a 
**	child field, in a field with a bias of FB_CHANGEABLE
**	ApplyTemplate will change the contents of this event block
*/
ON Childvalidate =
BEGIN
   callproc UtSqueezeCharFldsP(c_frame = curframe);
END;

#  include UtHelpMenuScript

on click menu.file.close_menu,
on click close_btn,
on windowclose=
begin
#  include UtHelpMenuClose
   return;
end;

on childentry node_tbl =
begin
if loadcustfrom != 'NewNodeField' then
	selrow = 0;
	selrow = field(node_tbl).currow;
	callproc Load_Customer(which_row = :selrow); 
endif;

IF loadcustfrom = 'NewNodeField' then
	loadcustfrom = UT_EMPTYSTRING;
ENDIF;
end;

/*
** Template Added
** 	The ChildSetValue event is triggered for a composite field when a user changes the value of a 
**	child field, in a field with a bias of FB_CHANGEABLE
**	ApplyTemplate will change the contents of this event block
*/
procedure SetFrameMode ( cur_mode = smallint not null ) =
begin

   CurFrame.CurMode = cur_mode;

   if ( cur_mode = FM_QUERY ) then
	fm_mode = 'Inquiry';
   elseif ( cur_mode = FM_UPDATE ) then
	fm_mode = 'Update';
   elseif ( cur_mode = FM_USER1 ) then
	fm_mode = 'Add';
   elseif ( cur_mode = FM_USER2 ) then
	fm_mode = 'Delete';
   else
	message 'Invalid mode passed to SetFrameMode.';
	resume;
   endif;

   callproc change_color_fields(ent_opt_array = byref(ent_opt_array));
end;
/*************************************************/
PROCEDURE Load_Node()=
DECLARE
v_so_salsm_mgrid = varchar(8) not null with default;
ENDDECLARE
BEGIN

rownum = 1;
node_tbl.clear();


SELECT :node_tbl[rownum].sfc_node_key = sfc_node_key,
	   :node_tbl[rownum].sfc_node_desc = sfc_node_desc
FROM sfc_node_tbl
WHERE gl_cmp_key = :company_id
AND so_brnch_key = :branch_id
AND sfc_nodetyp_key in ('DSR','DSA')
AND en_stats_key = 'Active'
BEGIN
rownum = rownum + 1;
END;
if ( iierrornumber !=0 ) then
	CallProc errortrap ( errornum = iierrornumber,
		frame_name = curframe.objectsource.name,
		tbl_name = 'sfc_node_tbl', 
		change_number = :change_number,
		id = '$_CurFld/1');
	rollback;
	resume;
endif;		
END;
/************************************************/
PROCEDURE Load_Customer(which_row = integer not null default 0;)=
DECLARE

unselectedrow = integer not null default 0;
selectedrow = integer not null default 0;
ENDDECLARE
BEGIN

ship_tbl.clear();
selrow = field(node_tbl).currow;
rownum = 1;

SELECT :ship_tbl[rownum].pc_spthdr_key = ar_ship_ext.pc_spthdr_key,
	   :ship_tbl[rownum].pc_spthdr_desc = pc_spthdr_tbl.pc_spthdr_desc,
	   :ship_tbl[rownum].ar_ship_key = ar_ship_ext.ar_ship_key,
	   :ship_tbl[rownum].ar_ship_name = ar_ship_tbl.ar_ship_name,
	   :ship_tbl[rownum].so_salsm_key = ar_ship_ext.so_salsm_key
FROM pc_spthdr_tbl, 
	 ar_ship_ext, 
	 en_cstjn_tbl,
	 ar_ship_tbl
WHERE pc_spthdr_tbl.gl_cmp_key = :company_id
AND pc_spthdr_tbl.so_brnch_key = :branch_id
AND pc_spthdr_tbl.sfc_node_key = :node_tbl[which_row].sfc_node_key
AND pc_spthdr_tbl.gl_cmp_key = ar_ship_ext.gl_cmp_key
AND pc_spthdr_tbl.so_brnch_key = ar_ship_ext.so_brnch_key
AND pc_spthdr_tbl.pc_spthdr_key = ar_ship_ext.pc_spthdr_key
AND ar_ship_ext.ar_ship_key = en_cstjn_tbl.en_ship_key
and en_cstjn_tbl.en_stats_key = 'Active'
AND ar_ship_ext.gl_cmp_key = ar_ship_tbl.gl_cmp_key
AND ar_ship_ext.ar_ship_key = ar_ship_tbl.ar_ship_key

BEGIN	
	SELECT :ship_tbl[rownum].so_salsm_name = so_salsm_name 
	FROM so_salsm_tbl
	WHERE gl_cmp_key = :company_id
	AND so_salsm_key = :ship_tbl[rownum].so_salsm_key;
	if ( iierrornumber !=0 ) then
		CallProc errortrap ( errornum = iierrornumber,
			frame_name = curframe.objectsource.name,
			tbl_name = 'so_salsm_tbl', 
			change_number = :change_number,
			id = '$_CurFld/1');
		rollback;
		resume;
	endif;	
	rownum =  rownum + 1;
END;

node_tbl[selrow].sel_tgl = 1;
for unselectedrow = 1 to node_tbl.lastrow do
	IF :unselectedrow != :selrow THEN
		:node_tbl[unselectedrow].sel_tgl = 0;

	ENDIF;
endfor;
END;
/*******************************************************************/
PROCEDURE set_color() =
BEGIN
	CALLPROC secure_frame (client_frame = BYREF(CURFRAME));
	CALLPROC change_color_FIELDs(ent_opt_array = :ent_opt_array);
END;


