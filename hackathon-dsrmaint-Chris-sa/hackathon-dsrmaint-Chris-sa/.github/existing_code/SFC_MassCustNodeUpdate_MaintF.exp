758:ON SETVALUE =
DECLARE
ENDDECLARE
BEGIN

sfc_node_desc = ut_emptystring;
SELECT :sfc_node_key = sfc_node_key,
	   :sfc_node_desc = sfc_node_desc
FROM sfc_node_tbl
WHERE gl_cmp_key = :company_id
AND so_brnch_key = :branch_id
AND sfc_node_key = :sfc_node_key
AND sfc_nodetyp_key in ('DSR','DSA')
AND en_stats_key = 'Active';

if ( iierrornumber !=0 ) then
		CallProc errortrap ( errornum = iierrornumber,
			frame_name = curframe.objectsource.name,
			tbl_name = 'sfc_node_tbl', 
			change_number = :change_number,
			id = '$_CurFld/1');
		resume;
        endif;

	if ( IIrowcount = 0 ) then
		curframe.beep(); 		
		MESSAGE 'Node Key does not exists!';
		sfc_node_key = 0;
		RESUME;		
	endif;
	
loadcustfrom = 'NewNodeField';

/*callproc Load_Customer();*/
END;

