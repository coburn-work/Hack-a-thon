659:ON SETVALUE =
DECLARE
ENDDECLARE
BEGIN

en_sltyp_desc = ut_emptystring;
SELECT :en_sltyp_key = en_sltyp_key, 
       :en_sltyp_desc = en_sltyp_desc 
FROM en_sltyp_tbl
WHERE en_sltyp_key = :en_sltyp_key;

if ( iierrornumber !=0 ) then
		CallProc errortrap ( errornum = iierrornumber,
			frame_name = curframe.objectsource.name,
			tbl_name = 'en_sltyp_tbl', 
			change_number = :change_number,
			id = '$_CurFld/1');
		resume;
        endif;

	if ( IIrowcount = 0 ) then
		curframe.beep(); 		
		MESSAGE 'Sales Type does not exists!';
		en_sltyp_key = ut_emptystring;
		RESUME;		
	endif;
	
loadcustfrom = 'NewSalesTypeField';

/*callproc Load_Customer();*/
END;

