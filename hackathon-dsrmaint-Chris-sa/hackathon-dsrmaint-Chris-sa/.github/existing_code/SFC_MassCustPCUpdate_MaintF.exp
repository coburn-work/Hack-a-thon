3316:on click =      /* update_btn */
declare
selected_rowcount	= integer not null default 0;
saletyperow = integer not null default 0;
i			= integer not null default 1;
enddeclare
begin

IF en_sltyp_key = ut_emptystring THEN
	CURFRAME.BEEP();
	MESSAGE 'Sales Type field cannot be blank!';
	CURFRAME.INPUTFOCUSFIELD = FIELD(en_sltyp_key);
	RESUME;
ENDIF;
FOR i = 1 TO salestype_tbl.LASTROW do	
	IF :salestype_tbl[i].sel_tgl = 1 AND salestype_tbl[i].en_sltyp_key != UT_EMPTYSTRING THEN
		saletyperow = i;
	ENDIF;
ENDFOR;
IF CurFrame.ConfirmPopup( messagetext = 'Are You Sure You Want To update the selected items?') = PU_OK THEN
	selrow = 1;
	FOR selrow = 1 TO  ship_tbl.LastRow do
			IF ship_tbl[selrow]._rowSelected = TRUE 
				and ship_tbl[selrow].en_ship_key != ut_emptystring then
				
				/*UPDATE TABLES HERE*/
				UPDATE so_salsm_ext
				SET en_sltyp_key = :en_sltyp_key
				WHERE gl_cmp_key = :company_id
				AND so_salsm_key = :ship_tbl[selrow].so_salsm_key;
	
				if ( iierrornumber !=0 ) then
					CallProc errortrap ( errornum = iierrornumber,
						frame_name = curframe.objectsource.name,
						tbl_name = 'so_salsm_ext', 
						change_number = :change_number,
						id = '$_CurFld/1');
					rollback;
					resume;
				endif;
							
				/*UPDATE en_cust_tbl
				SET en_sltyp_key = :en_sltyp_key
				WHERE en_cust_key in (select ar_ship_key
									  FROM ar_ship_ext
									  WHERE gl_cmp_key = :company_id
									  AND so_brnch_key = :branch_id
									  AND so_salsm_key = :ship_tbl[selrow].so_salsm_key)
				AND en_sltyp_key = :salestype_tbl[saletyperow].en_sltyp_key;*/
				
				UPDATE en_cust_tbl
				SET en_sltyp_key = :en_sltyp_key
				WHERE en_sltyp_key = :salestype_tbl[saletyperow].en_sltyp_key
				AND en_cust_key = :ship_tbl[selrow].en_ship_key;
	
				if ( iierrornumber !=0 ) then
					CallProc errortrap ( errornum = iierrornumber,
						frame_name = curframe.objectsource.name,
						tbl_name = 'en_cust_tbl', 
						change_number = :change_number,
						id = '$_CurFld/1');
					rollback;
					resume;
				endif;
												 
				/*UPDATE en_ship_tbl
	       		SET en_sltyp_key = :en_sltyp_key
	     		WHERE en_ship_key IN (SELECT ar_ship_key
	               					  FROM ar_ship_ext
	              					  WHERE gl_cmp_key = :company_id
	                				  AND so_brnch_key = :branch_id
	                                  AND so_salsm_key = :ship_tbl[selrow].so_salsm_key)
	       AND en_sltyp_key = :salestype_tbl[saletyperow].en_sltyp_key;*/
	       
	       		UPDATE en_ship_tbl
				SET en_sltyp_key = :en_sltyp_key
				WHERE en_sltyp_key = :salestype_tbl[saletyperow].en_sltyp_key
				AND en_ship_key = :ship_tbl[selrow].en_ship_key;
				
				if ( iierrornumber !=0 ) then
					CallProc errortrap ( errornum = iierrornumber,
						frame_name = curframe.objectsource.name,
						tbl_name = 'en_ship_tbl', 
						change_number = :change_number,
						id = '$_CurFld/1');
					rollback;
					resume;
				endif;
				
				
				commit;
				selected_rowcount = selected_rowcount + 1;
				
			ENDIF;
	ENDFOR;
	
	IF selected_rowcount <= 0 then
		CURFRAME.BEEP();
		MESSAGE 'Please select valid rows from the customer table.';
		RESUME;
	ENDIF;
		
	CALLPROC Load_SalesType();
	CALLPROC Load_Customer(which_row = 1);	
	CallProc SetFrameMode ( cur_mode = FM_QUERY );
ENDIF;

end;       




