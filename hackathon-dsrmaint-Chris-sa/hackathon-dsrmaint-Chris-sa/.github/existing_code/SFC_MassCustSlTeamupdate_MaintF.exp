0
707:ON SETVALUE =
DECLARE
ENDDECLARE
BEGIN
sfc_slteam_desc = ut_emptystring;
SELECT :sfc_slteam_key = sfc_slteam_key, 
       :sfc_slteam_desc = sfc_slteam_desc
FROM sfc_slteam_tbl
WHERE gl_cmp_key = :company_id
AND so_brnch_key = :branch_id
AND sfc_slteam_key = :sfc_slteam_key;

if ( iierrornumber !=0 ) then
		CallProc errortrap ( errornum = iierrornumber,
			frame_name = curframe.objectsource.name,
			tbl_name = 'sfc_slteam_tbl', 
			change_number = :change_number,
			id = '$_CurFld/1');
		resume;
        endif;

	if ( IIrowcount = 0 ) then
		curframe.beep(); 		
		MESSAGE 'Sales Team key does not exists!';
		sfc_slteam_key = ut_emptystring;
		RESUME;		
	endif;
loadcustfrom = 'NewSalesTeamField';
END;

