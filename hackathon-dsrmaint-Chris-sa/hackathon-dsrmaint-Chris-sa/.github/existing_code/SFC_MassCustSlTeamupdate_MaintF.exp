1508:on click =      /* update_btn */
declare
selected_rowcount	= integer not null default 0;
enddeclare
begin

IF sfc_slteam_key = ut_emptystring THEN
	CURFRAME.BEEP();
	MESSAGE 'New Sales Type field cannot be blank!';
	CURFRAME.INPUTFOCUSFIELD = FIELD(sfc_slteam_key);
	RESUME;
ENDIF;
IF CurFrame.ConfirmPopup( messagetext = 'Are You Sure You Want To update the selected items?') = PU_OK THEN
	selrow = 1;
	FOR selrow = 1 TO  ship_tbl.LastRow do
			IF ship_tbl[selrow]._rowSelected = TRUE 
				and ship_tbl[selrow].ar_ship_key != ut_emptystring then
				
				/*UPDATE TABLES HERE*/
				UPDATE ar_ship_ext
				SET sfc_slteam_key = :sfc_slteam_key
				WHERE gl_cmp_key = :company_id
				AND so_brnch_key = :branch_id
				AND ar_ship_key = :ship_tbl[selrow].ar_ship_key;
				
				if ( iierrornumber !=0 ) then
					CallProc errortrap ( errornum = iierrornumber,
						frame_name = curframe.objectsource.name,
						tbl_name = 'ar_ship_ext', 
						change_number = :change_number,
						id = '$_CurFld/1');
					rollback;
					resume;
				endif;
				
				if ( IIrowcount > 0 ) then
					curframe.beep(); 		
					/*MESSAGE 'Updated Successfully!';*/
					commit;
					selected_rowcount = selected_rowcount + 1;
				endif;
			ENDIF;
	ENDFOR;
	
	IF selected_rowcount <= 0 then
		CURFRAME.BEEP();
		MESSAGE 'Please select valid rows from the customer table.';
		RESUME;
	ENDIF;
		
	CALLPROC Load_SalesTeam();
	CALLPROC Load_Customer(which_row = 1);	
	CallProc SetFrameMode ( cur_mode = FM_QUERY );
ENDIF;

end;       



